app:
  name: "requirement-delivery-api"
  version: "dev"
  port: 8080
  mode: "release"
  base_url: "http://<YOUR_SERVER_IP>"
  frontend_url: "http://<YOUR_SERVER_IP>"
  session_cookie_name: "feishu_pipeline_session"
  cookie_secure: false
  cookie_same_site: "lax"
  session_ttl_hours: 168

database:
  path: "./data/requirement-delivery.db"

feishu:
  enabled: true
  app_id: "<YOUR_FEISHU_APP_ID>"
  app_secret: "<YOUR_FEISHU_APP_SECRET>"
  redirect_url: "http://<YOUR_SERVER_IP>/auth/callback"
  open_base_url: "https://open.feishu.cn"
  oauth_scope: "contact:contact.base:readonly contact:user.department:readonly contact:user.department_path:readonly"
  bot_name: "需求交付机器人"
  receive_id_type: "open_id"
  doc_folder_token: "<YOUR_DOC_FOLDER_TOKEN>"
  bitable_name: "需求排期"
  bitable_folder_token: ""
  bitable_app_token: ""
  bitable_table_id: ""
  bitable_template_token: "<YOUR_BITABLE_TEMPLATE_TOKEN>"

ai:
  provider: "ark"
  ark:
    base_url: "https://ark.cn-beijing.volces.com/api/v3"
    model: "doubao-seed-2-0-lite-260215"
    api_key: "<YOUR_ARK_API_KEY>"
    temperature: 0.2
    max_tokens: 4096
    timeout_sec: 120
