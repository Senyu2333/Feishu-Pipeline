{
	"info": {
		"_postman_id": "a1b2c3d4-feishu-pipeline-api",
		"name": "Feishu Pipeline API",
		"description": "Requirement Delivery API（Gin）。\n\n**统一响应**：成功 `{\"data\": ...}`，失败 `{\"error\": \"...\"}`。\n\n**认证**：登录接口成功后会通过 `Set-Cookie` 写入 HttpOnly 会话（默认 cookie 名见配置 `session_cookie_name`，常为 `feishu_pipeline_session`）。在 Postman 中请开启 **Send cookies**（默认开启），先调用「飞书 SSO 登录」再调需登录接口；需与 `baseUrl` 同主机名端口，Cookie 才会自动带上。\n\n**变量**：在 Collection Variables 中设置 `baseUrl`（默认 `http://localhost:8080`），以及路径参数 `sessionID`、`taskID` 等。",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "sessionID",
			"value": ""
		},
		{
			"key": "taskID",
			"value": ""
		},
		{
			"key": "feishu_code",
			"value": ""
		}
	],
	"item": [
		{
			"name": "01 公开接口",
			"item": [
				{
					"name": "健康检查 GET /api/health",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/health",
						"description": "返回 status、service、version、now（UTC RFC3339）。"
					},
					"response": []
				},
				{
					"name": "飞书 SSO 配置 GET /api/auth/feishu/config",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/auth/feishu/config",
						"description": "前端用于展示是否启用 SSO 及 appId。`data`: `{ enabled, appId }`"
					},
					"response": []
				},
				{
					"name": "飞书 SSO 登录 POST /api/auth/feishu/sso/login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"code\": \"{{feishu_code}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/api/auth/feishu/sso/login",
						"description": "Body 必填字段：`code`（飞书 OAuth 授权码）。\n成功 200：`data` 含 `user`（id, feishuOpenID, name, email, role, departments），并 Set-Cookie。\n失败常见：400 参数错误；502 上游/登录失败。"
					},
					"response": []
				},
				{
					"name": "登出 POST /api/auth/logout",
					"request": {
						"method": "POST",
						"header": [],
						"url": "{{baseUrl}}/api/auth/logout",
						"description": "清除服务端会话与 Cookie。`data`: `{ \"status\": \"logged_out\" }`。若带有效 Cookie 则按该会话登出。"
					},
					"response": []
				}
			]
		},
		{
			"name": "02 需登录（Cookie）",
			"item": [
				{
					"name": "当前用户 GET /api/me",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/me",
						"description": "需有效会话 Cookie。401 未登录。\n`data`: 用户对象（id, feishuOpenID, name, email, role, departments）。\n`role`: product | frontend | backend | admin"
					},
					"response": []
				},
				{
					"name": "会话列表 GET /api/sessions",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/sessions",
						"description": "`data`: 数组，元素含 id, title, summary, status, ownerName, messageCount, updatedAt。\n`status` 会话：draft | published | in_delivery | testing | done | archived"
					},
					"response": []
				},
				{
					"name": "创建会话 POST /api/sessions",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"示例需求标题\",\n  \"prompt\": \"示例初始提示/需求描述\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/api/sessions",
						"description": "Body 必填：`title`, `prompt`。\n成功 201：`data` 为会话详情（见「会话详情」）。"
					},
					"response": []
				},
				{
					"name": "会话详情 GET /api/sessions/:sessionID",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/sessions/{{sessionID}}",
						"description": "`data`: session（摘要）, messages[], requirement（可缺省）, tasks[]。\n消息 role: user | assistant | system。\n404 会话不存在。"
					},
					"response": []
				},
				{
					"name": "追加消息 POST /api/sessions/:sessionID/messages",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"content\": \"用户补充说明\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/api/sessions/{{sessionID}}/messages",
						"description": "Body 必填：`content`。\n成功 201：`data` 为更新后的完整会话详情。"
					},
					"response": []
				},
				{
					"name": "发布会话 POST /api/sessions/:sessionID/publish",
					"request": {
						"method": "POST",
						"header": [],
						"url": "{{baseUrl}}/api/sessions/{{sessionID}}/publish",
						"description": "异步受理需求。成功 202：`data` 含 status=accepted 与提示文案。失败 400。"
					},
					"response": []
				},
				{
					"name": "任务详情 GET /api/tasks/:taskID",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/tasks/{{taskID}}",
						"description": "`data`: 任务全字段（id, sessionId, title, description, type, status, priority, estimateDays, assignee*, docURL, bitableRecordURL, acceptanceCriteria, risks, createdAt, updatedAt 等）。\ntype: frontend | backend | shared。\n404 不存在。"
					},
					"response": []
				},
				{
					"name": "更新任务状态 PATCH /api/tasks/:taskID/status",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"in_progress\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/api/tasks/{{taskID}}/status",
						"description": "Body 必填：`status`。\n允许值：todo | in_progress | testing | done。\n成功 200：`data` 为更新后的任务对象。"
					},
					"response": []
				}
			]
		},
		{
			"name": "03 管理员（role=admin）",
			"item": [
				{
					"name": "创建角色映射 POST /api/admin/role-mappings",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"规则名称\",\n  \"keyword\": \"匹配关键词\",\n  \"role\": \"product\",\n  \"departments\": [\"部门A\"]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/api/admin/role-mappings",
						"description": "必填：name, keyword, role。departments 可选数组。\nrole: product | frontend | backend | admin。\n成功 201：`data` `{ \"status\": \"saved\" }`。\n403 非管理员。"
					},
					"response": []
				},
				{
					"name": "角色负责人列表 GET /api/admin/role-owners",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/api/admin/role-owners",
						"description": "`data`: 数组，元素含 id, role, ownerName, feishuId, feishuIdType, enabled。"
					},
					"response": []
				},
				{
					"name": "保存角色负责人 POST /api/admin/role-owners",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"role\": \"frontend\",\n  \"ownerName\": \"负责人姓名\",\n  \"feishuId\": \"\",\n  \"feishuIdType\": \"\",\n  \"enabled\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/api/admin/role-owners",
						"description": "必填：role, ownerName。feishuId / feishuIdType 可选。\n成功 201：`data` `{ \"status\": \"saved\" }`。"
					},
					"response": []
				},
				{
					"name": "同步知识库 POST /api/admin/knowledge/sync",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"sources\": [\n    {\n      \"title\": \"条目标题\",\n      \"content\": \"条目正文内容\"\n    }\n  ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/api/admin/knowledge/sync",
						"description": "必填：`sources` 数组，每项含 title, content。\n成功 201：`data` `{ \"count\": <写入条数> }`。"
					},
					"response": []
				}
			]
		}
	]
}
