{
  "name": "feishu-pipeline",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:api-ts": "pnpm --filter api-ts dev",
    "dev:api-py": "pnpm --filter api-py dev",
    "build": "pnpm --filter web build",
    "preview": "pnpm --filter web preview",
    "lint": "pnpm -r lint",
    "swagger:gen": "cd apps/api-go && go run github.com/swaggo/swag/cmd/swag@latest init -g main.go -o docs",
    "apifox:sync": "pnpm swagger:gen && node scripts/sync-apifox.mjs apps/api-go/docs/swagger.json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-checker": "^0.8.0"
  }
}
